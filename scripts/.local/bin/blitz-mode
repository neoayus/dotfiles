#!/usr/bin/env bash

blitz_mode=$(hyprctl getoption animations:enabled | awk 'NR==1{print $2}')

if [ "$blitz_mode" = "1" ]; then
    # Enable BLITZ mode (performance)
    hyprctl --batch "
        keyword animations:enabled 0;
        keyword decoration:blur:enabled 0;
        keyword decoration:shadow:enabled 0;
        keyword decoration:active_opacity 1;
        keyword decoration:inactive_opacity 1;
        keyword general:gaps_in 0;
        keyword general:gaps_out 0;
        keyword general:border_size 1;
    "
    notify-send "Blitz Mode" "Performance mode enabled"
else
    # Return to normal config
    hyprctl reload
    notify-send "Blitz Mode" "Normal mode restored"
fi
